# LLM API Configuration (OpenAI-compatible)
LAB_TUTOR_LLM_API_KEY=your_llm_api_key_here
LAB_TUTOR_LLM_BASE_URL=https://api.silra.cn/v1/
LAB_TUTOR_LLM_MODEL=deepseek-v3.2

# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# LangSmith Configuration for Tracing and Debugging
LANGCHAIN_TRACING_V2=true
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=concept-relationship-detection

# Optional: LangSmith endpoint (defaults to https://api.smith.langchain.com)
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
