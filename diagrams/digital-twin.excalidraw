    {
      "id": "dt_4_b",
      "type": "text",
      "x": 496,
      "y": 656,
      "width": 708,
      "height": 113,
      "angle": 0,
      "strokeColor": "#1a2e1a",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 1031,
      "version": 1,
      "versionNonce": 1031,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1703000000000,
      "link": null,
      "locked": false,
      "text": "  coherence  =  0.4 × proximity  +  0.3 × gradient  +  0.3 × zpd_cluster\n\n  proximity   =  |{ (i,j) : |idx_i − idx_j| ≤ 2 }|  /  C(n,2)\n  gradient    =  |{ i : 0.05 ≤ m_{i+1} − m_i ≤ 0.30 }|  /  (n−1)\n  zpd_cluster =  |{ s : m_s ∈ [0.30, 0.70] }|  /  n",
      "fontSize": 11,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "  coherence  =  0.4 × proximity  +  0.3 × gradient  +  0.3 × zpd_cluster\n\n  proximity   =  |{ (i,j) : |idx_i − idx_j| ≤ 2 }|  /  C(n,2)\n  gradient    =  |{ i : 0.05 ≤ m_{i+1} − m_i ≤ 0.30 }|  /  (n−1)\n  zpd_cluster =  |{ s : m_s ∈ [0.30, 0.70] }|  /  n",
      "lineHeight": 1.3
    },
