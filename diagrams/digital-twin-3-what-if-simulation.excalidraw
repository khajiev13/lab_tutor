    {
      "id": "b_f3_preview_c",
      "type": "text",
      "x": 618,
      "y": 684,
      "width": 560,
      "height": 116,
      "angle": 0,
      "strokeColor": "#1e293b",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 249,
      "version": 1,
      "versionNonce": 250,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1703000000000,
      "link": null,
      "locked": false,
      "text": "computeCoherencePreview(skillIds, mastery):\n  proximity = connected_pairs / total_pairs\n  zpd = skills in [0.3,0.7] / n\n  score = 0.6*proximity + 0.4*zpd\n\nmanualImpactPreview:\n  avgBefore / projectedGain / avgAfter\n  topContributors[0..4] sorted by gain desc\n  gain = (1-m)*0.13*w*(1+coh*0.2)*timeScale\n  timeScale = 1 - exp(-days/3.5)",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "computeCoherencePreview(skillIds, mastery):\n  proximity = connected_pairs / total_pairs\n  zpd = skills in [0.3,0.7] / n\n  score = 0.6*proximity + 0.4*zpd\n\nmanualImpactPreview:\n  avgBefore / projectedGain / avgAfter\n  topContributors[0..4] sorted by gain desc\n  gain = (1-m)*0.13*w*(1+coh*0.2)*timeScale\n  timeScale = 1 - exp(-days/3.5)",
      "lineHeight": 1.4
    },
