      "roundness": null,
      "seed": 175,
      "version": 1,
      "versionNonce": 176,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1703000000000,
      "link": null,
      "locked": false,
      "text": "trajectory = 16 sampled timeline checkpoints\n  step = max(1, floor(timeline.length / 16))\n  always includes last entry\n\nLineChart:\n  X: \"T{step}\" strings  \u00b7  Y: avgMastery %\n  60% ReferenceLine (amber dashed)\n  Line: stroke #f97316, dot r=3\n  Tooltip: date (from payload.date) + avg mastery\n\nHidden when timeline.length < 2",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "trajectory = 16 sampled timeline checkpoints\n  step = max(1, floor(timeline.length / 16))\n  always includes last entry\n\nLineChart:\n  X: \"T{step}\" strings  \u00b7  Y: avgMastery %\n  60% ReferenceLine (amber dashed)\n  Line: stroke #f97316, dot r=3\n  Tooltip: date (from payload.date) + avg mastery\n\nHidden when timeline.length < 2",
      "lineHeight": 1.4
    },
