    {
      "id": "b_traj_c",
      "type": "text",
      "x": 22,
      "y": 624,
      "width": 554,
      "height": 188,
      "angle": 0,
      "strokeColor": "#1e293b",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
