      "boundElements": [],
      "updated": 1703000000000,
      "link": null,
      "locked": false,
      "text": "avgM     = avg(final_mastery[])              atRisk = mastery.filter(v<0.5).length\nabove75  = mastery.filter(v>=0.75).length      isCurrentStudent = uid === student.uid\ntrend    = compare firstHalf vs secondHalf of timeline avg mastery\n  secondHalf \u2212 firstHalf > 0.01 \u2192 \"up\"  |  > 0.01 other way \u2192 \"down\"  |  else \"neutral\"\nsorted: avgM asc (most at-risk first)",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "avgM     = avg(final_mastery[])              atRisk = mastery.filter(v<0.5).length\nabove75  = mastery.filter(v>=0.75).length      isCurrentStudent = uid === student.uid\ntrend    = compare firstHalf vs secondHalf of timeline avg mastery\n  secondHalf \u2212 firstHalf > 0.01 \u2192 \"up\"  |  > 0.01 other way \u2192 \"down\"  |  else \"neutral\"\nsorted: avgM asc (most at-risk first)",
      "lineHeight": 1.4
