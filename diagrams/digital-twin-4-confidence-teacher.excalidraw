    {
      "id": "b_conf_metrics_c",
      "type": "text",
      "x": 22,
      "y": 132,
      "width": 544,
      "height": 160,
      "angle": 0,
      "strokeColor": "#1e293b",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 283,
      "version": 1,
      "versionNonce": 284,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1703000000000,
      "link": null,
      "locked": false,
      "text": "computed from:\n  pairs = timeline.filter(e => e.predicted_prob != null)\n  requires pairs.length >= 2\n\n[Prediction Quality]  classificationAcc = correct_direction / pairs.length\n  correct_direction: predicted>=0.5 == (response===1)\n\n[Calibration Score]  brierScore = avg((predicted_prob - response)\u00b2)  \u2190 lower is better\n\n[Avg P(correct)]     avgPredicted = avg(predicted_prob) over all pairs\n\n[Quality badge]\n  brierScore > 0.25  \u2192 Needs Calibration  (destructive)\n  brierScore > 0.15  \u2192 Fair\n  else               \u2192 Well Calibrated    (secondary)",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "computed from:\n  pairs = timeline.filter(e => e.predicted_prob != null)\n  requires pairs.length >= 2\n\n[Prediction Quality]  classificationAcc = correct_direction / pairs.length\n  correct_direction: predicted>=0.5 == (response===1)\n\n[Calibration Score]  brierScore = avg((predicted_prob - response)\u00b2)  \u2190 lower is better\n\n[Avg P(correct)]     avgPredicted = avg(predicted_prob) over all pairs\n\n[Quality badge]\n  brierScore > 0.25  \u2192 Needs Calibration  (destructive)\n  brierScore > 0.15  \u2192 Fair\n  else               \u2192 Well Calibrated    (secondary)",
      "lineHeight": 1.4
    },
