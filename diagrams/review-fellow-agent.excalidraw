      "roundness": null, "seed": 137, "version": 1, "versionNonce": 137,
      "isDeleted": false, "boundElements": [], "updated": 1703000000000, "link": null, "locked": false,
      "text": "u = w_pco*is_pco\n  + w_decay*decay\n  + w_streak*streak\n  + w_mastery*(1-m)\n  + w_recent*recency",
      "fontSize": 12, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "containerId": null, "originalText": "u = w_pco*is_pco\n  + w_decay*decay\n  + w_streak*streak\n  + w_mastery*(1-m)\n  + w_recent*recency", "lineHeight": 1.5
    },
