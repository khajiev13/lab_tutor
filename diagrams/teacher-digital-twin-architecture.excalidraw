      "updated": 1703000001012,
      "link": null,
      "locked": false,
      "text": "Cross-module dependencies\n\n- CognitiveDiagnosisService.generate_exercise()\n  for single-skill and multi-skill simulation\n- CognitiveDiagnosisService.get_arcd_portfolio()\n  for teacher read-only portfolio drilldown\n- CognitiveDiagnosisService.get_arcd_twin()\n  for teacher read-only student twin drilldown",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Cross-module dependencies\n\n- CognitiveDiagnosisService.generate_exercise()\n  for single-skill and multi-skill simulation\n- CognitiveDiagnosisService.get_arcd_portfolio()\n  for teacher read-only portfolio drilldown\n- CognitiveDiagnosisService.get_arcd_twin()\n  for teacher read-only student twin drilldown",
      "lineHeight": 1.2
    },
