      "versionNonce": 5027,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1703000001027,
      "link": null,
      "locked": false,
      "text": "4. Student Groups  GET /student-groups\nTier logic:\nadvanced >= 0.80, developing 0.50-0.79, foundational < 0.50\nAggregates members, skill_set, group_avg_mastery, and suggested_path\nSuggested path uses ZPD-biased ordering of lowest average mastery skills",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "4. Student Groups  GET /student-groups\nTier logic:\nadvanced >= 0.80, developing 0.50-0.79, foundational < 0.50\nAggregates members, skill_set, group_avg_mastery, and suggested_path\nSuggested path uses ZPD-biased ordering of lowest average mastery skills",
      "lineHeight": 1.2
    },
