    {
      "id": "ttd_schema_text3",
      "type": "text",
      "x": 1196,
      "y": 1036,
      "width": 528,
      "height": 298,
      "angle": 0,
      "strokeColor": "#0f172a",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 5055,
      "version": 1,
      "versionNonce": 5055,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1703000001055,
      "link": null,
      "locked": false,
      "text": "Key request / response DTO map\n\nRequests\n- WhatIfRequest { mode, skills?, delta, top_k, target_gain, enable_llm }\n- WhatIfSkill { skill_name, hypothetical_mastery }\n- SkillSimulationRequest { skill_name, simulated_mastery }\n- MultiSkillSimulationRequest { mode, skills[], top_k, default_mastery }\n- SkillTarget { skill_name, simulated_mastery? }\n\nResponses\n- StudentMasterySummary { user_id, full_name, email, selected_skill_count,\n  avg_mastery, mastered_count, struggling_count, pco_count, at_risk }\n- SkillInterventionImpact { skill_name, current_avg_mastery,\n  simulated_avg_mastery, class_gain, students_helped, recommendation_score }\n- SkillCoherenceResult { overall_score, label, pairs,\n  teaching_order, clusters, common_students }\n- ArcdTwinViewerData and ArcdPortfolioData are reused for teacher drilldown",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Key request / response DTO map\n\nRequests\n- WhatIfRequest { mode, skills?, delta, top_k, target_gain, enable_llm }\n- WhatIfSkill { skill_name, hypothetical_mastery }\n- SkillSimulationRequest { skill_name, simulated_mastery }\n- MultiSkillSimulationRequest { mode, skills[], top_k, default_mastery }\n- SkillTarget { skill_name, simulated_mastery? }\n\nResponses\n- StudentMasterySummary { user_id, full_name, email, selected_skill_count,\n  avg_mastery, mastered_count, struggling_count, pco_count, at_risk }\n- SkillInterventionImpact { skill_name, current_avg_mastery,\n  simulated_avg_mastery, class_gain, students_helped, recommendation_score }\n- SkillCoherenceResult { overall_score, label, pairs,\n  teaching_order, clusters, common_students }\n- ArcdTwinViewerData and ArcdPortfolioData are reused for teacher drilldown",
      "lineHeight": 1.2
    }
  ],
