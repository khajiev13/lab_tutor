      "updated": 1703000001025,
      "link": null,
      "locked": false,
      "text": "3. Class Mastery  GET /class-mastery\nBuilds StudentMasterySummary rows from class mastery + PCO counts\nat_risk = avg_mastery < 0.50 OR pco_count > 2\nAlso computes class_avg_mastery, at_risk_count, total_students",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "3. Class Mastery  GET /class-mastery\nBuilds StudentMasterySummary rows from class mastery + PCO counts\nat_risk = avg_mastery < 0.50 OR pco_count > 2\nAlso computes class_avg_mastery, at_risk_count, total_students",
      "lineHeight": 1.2
    },
