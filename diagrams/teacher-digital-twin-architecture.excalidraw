      "link": null,
      "locked": false,
      "text": "Analytics responses\n\nSkillDifficultyResponse\n- course_id\n- skills[{skill_name, student_count, avg_mastery, perceived_difficulty}]\n- total_skills\n\nSkillPopularityResponse\n- course_id, all_skills, most_popular, least_popular, total_students\n\nClassMasteryResponse\n- course_id, students[StudentMasterySummary], class_avg_mastery,\n  at_risk_count, total_students",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Analytics responses\n\nSkillDifficultyResponse\n- course_id\n- skills[{skill_name, student_count, avg_mastery, perceived_difficulty}]\n- total_skills\n\nSkillPopularityResponse\n- course_id, all_skills, most_popular, least_popular, total_students\n\nClassMasteryResponse\n- course_id, students[StudentMasterySummary], class_avg_mastery,\n  at_risk_count, total_students",
      "lineHeight": 1.2
    },
