    {
      "id": "ttd_schema_text2",
      "type": "text",
      "x": 576,
      "y": 1036,
      "width": 568,
      "height": 298,
      "angle": 0,
      "strokeColor": "#0f172a",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 5053,
      "version": 1,
      "versionNonce": 5053,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1703000001053,
      "link": null,
      "locked": false,
      "text": "Neo4j relationships and properties\n\nSTUDENT -> CLASS ENROLLED_IN_CLASS\nSTUDENT -> SKILL SELECTED_SKILL\nSTUDENT -> SKILL MASTERED\n- mastery, status, decay, attempt_count, correct_count, updated_at_ts\n\nSTUDENT -> QUESTION ATTEMPTED\n- is_correct, timestamp_sec, attempt_number, time_spent_sec\n\nSTUDENT -> READING_RESOURCE or VIDEO_RESOURCE ENGAGES_WITH\n- progress, duration_sec, event_type, started_at\n\nSKILL -> SKILL PREREQUISITE_OF\n- weight\n\nTeacher-specific permission check\nteacher_teaches_class(teacher_id, course_id)\n- used before exposing student portfolio or student twin drilldown",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Neo4j relationships and properties\n\nSTUDENT -> CLASS ENROLLED_IN_CLASS\nSTUDENT -> SKILL SELECTED_SKILL\nSTUDENT -> SKILL MASTERED\n- mastery, status, decay, attempt_count, correct_count, updated_at_ts\n\nSTUDENT -> QUESTION ATTEMPTED\n- is_correct, timestamp_sec, attempt_number, time_spent_sec\n\nSTUDENT -> READING_RESOURCE or VIDEO_RESOURCE ENGAGES_WITH\n- progress, duration_sec, event_type, started_at\n\nSKILL -> SKILL PREREQUISITE_OF\n- weight\n\nTeacher-specific permission check\nteacher_teaches_class(teacher_id, course_id)\n- used before exposing student portfolio or student twin drilldown",
      "lineHeight": 1.2
    },
    {
      "id": "ttd_schema_box3",
